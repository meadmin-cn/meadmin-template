  "bugs": {
    "url": "https://github.com/meadmin-cn/meadmin-template/issues"
  },
  "homepage": "https://github.com/meadmin-cn/meadmin-template",
  "lint-staged": {
    "**/*": "prettier --cache --write --ignore-unknown",
    "*.{vue,ts,tsx}": "eslint --cache --fix"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
