{
  "name": "meadmin-template",
  "private": true,
  "version": "1.2.2",
  "type": "module",
  "author": {
    "name": "meadmin-cn",
    "email": "yuntian001z@qq.com",
    "url": "https://github.com/yuntian001"
  },
  "scripts": {
    "format": "prettier --write --cache .",
    "dev": "vite",
    "build": "npm run type-check && vite build -m prod ",
    "build-github": "npm run type-check && vite build -m prod --base=/meadmin-template/",
    "type-check": "npx tsx ./cli/autoImport.ts  && vue-tsc -b --noEmit",
    "preview": "vite preview",
    "release-main": "release-it -c .release-it-main.json",
    "release-template": "release-it",
    "eslint": "eslint . --cache --ext .vue,.ts,.tsx",
    "eslint:fix": "eslint . --ext .vue,.ts,.tsx --fix",
    "prettier": "prettier --cache  -l \"./**/*\"",
    "prettier:fix": "prettier --write --cache  -l \"./**/*\"",
    "i": "npm install --registry=https://registry.npm.taobao.org && npx husky install"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.1.0",
    "@meadmin-cn/vite-plugin-mock": "^2.9.7",
    "@vue/shared": "^3.2.25",
    "@vueuse/core": "^9.1.0",
    "axios": "^1.6.5",
    "dayjs": "^1.11.3",
    "element-plus": "^2.9.2",
    "jquery": "^3.6.0",
    "js-cookie": "^3.0.1",
    "lodash-es": "^4.17.21",
    "mockjs": "^1.1.0",
    "nprogress": "^0.2.0",
    "path-browserify": "^1.0.1",
    "pinia": "^2.0.14",
    "qs": "^6.11.0",
    "vue": "^3.5.13",
    "vue-i18n": "^9.1.10",
    "vue-request": "^2.0.1",
    "vue-router": "^4.1.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.0.3",
    "@commitlint/config-conventional": "^17.0.3",
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^9.0.4",
    "@types/jquery": "^3.5.14",
    "@types/js-cookie": "^3.0.2",
    "@types/lodash-es": "^4.17.7",
    "@types/mockjs": "^1.0.6",
    "@types/node": "^22.12.0",
    "@types/nprogress": "^0.2.0",
    "@types/path-browserify": "^1.0.0",
    "@types/qs": "^6.9.7",
    "@vitejs/plugin-legacy": "^8.0.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "@yuntian001/vue-setup-extend": "^1.0.0",
    "autoprefixer": "^10.4.8",
    "core-js": "^3.25.3",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^8.0.1",
    "lint-staged": "^13.0.3",
    "postcss-plugin-px2rem": "^0.8.1",
    "prettier": "2.8.8",
    "release-it": "^17.11.0",
    "sass": "^1.53.0",
    "terser": "^5.46.1",
    "tsx": "^4.19.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "~8.0.10",
    "vite-plugin-autogeneration-import-file": "^3.0.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-svg-loader": "^5.1.0",
